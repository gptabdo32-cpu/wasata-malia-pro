# Production-safe template
NODE_ENV=development
PORT=3000

# Core application
VITE_APP_ID=wathiqly-app
DATABASE_URL=mysql://user:password@127.0.0.1:3306/wathiqly
OAUTH_SERVER_URL=https://auth.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:4173,https://app.example.com

# Security secrets (generate strong unique values)
JWT_SECRET=replace-me-with-a-long-random-secret
SERVER_SECRET=replace-me-with-a-long-random-secret
COOKIE_SECRET=replace-me-with-a-long-random-secret
ENCRYPTION_KEY=replace-me-with-a-long-random-secret

# Optional blockchain settings
CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.example.com
SMART_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
BLOCKCHAIN_PRIVATE_KEY=replace-me

# Uploads and runtime limits
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,application/pdf
ALLOW_DEV_IDENTITY_HEADERS=false
ALLOWED_UPLOAD_HOSTS=

# Optional integrations
REDIS_URL=redis://127.0.0.1:6379
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
OWNER_OPEN_ID=
